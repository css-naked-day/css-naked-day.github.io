{%- set title = title if title else "April 9 is CSS Naked Day" -%}
{%- set description = description | truncate(150, false, '…') if description else null -%}

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8">
		<title>{{ title }}</title>
		<link rel="icon" href="/favicon.ico">

		<script>
			const today = new Date();
			const isCSSND = today.getMonth() + 1 === 4 && today.getDate() === 9;

			if (isCSSND) {
				document.querySelector('html').classList.add('cssnd');
			}
		</script>

		<link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Chivo:900">
		<link rel="stylesheet" href="/setup/default.css">
		<meta name="viewport" content="initial-scale=1,width=device-width">
		<meta name="og:type" content="website">
		<meta property="og:title" content="{{ title }}">
		<meta property="og:image" content="https://css-naked-day.org/media/logo.png">

		{% if description -%}
			<meta property="description" content="{{ description }}">
			<meta property="og:description" content="{{ description }}">
		{% endif %}
	</head>

	<body>
		<div id="container">
			<div class="inner">
				<header>
					<h1>
						{%- if page.url != '/' %}<a href="/">{% endif %}
						{{- title -}}
						{% if page.url != '/' %}</a>{% endif -%}
					</h1>

					{% if subtitle %}
						<h2>{{ subtitle | safe }}</h2>
					{% endif %}
				</header>

				<hr>

				<section id="main_content">
					{{ content | safe }}
				</section>

				<footer>
					This is <a href="/">CSS Naked Day</a>. This page was generated by <a href="https://11ty.dev/">Eleventy</a> (<a href="https://source.css-naked-day.org/css-naked-day.org">view it on GitHub</a>). Tactile theme by <a href="https://x.com/jasonlong">Jason Long</a>.
				</footer>
			</div>
		</div>

		<template id="cssnd-callout">
			We are celebrating <strong>CSS Naked Day</strong>!
		</template>

		<script>
			if (isCSSND) {
				document.querySelector('body').prepend(document.querySelector('#cssnd-callout').content.cloneNode(true));
			}
		</script>
	</body>
</html>
